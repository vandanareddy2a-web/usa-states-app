<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Cap Quest — USA State Capitals Quiz &amp; Map | Learn All 50 Capitals</title>
  <meta name="description" content="Cap Quest is a postcard-themed quiz, flashcard game, and interactive map for learning all 50 U.S. state capitals. Play the quiz, explore states by region, and jump to full state profiles.">
  <meta name="keywords" content="state capitals quiz, US state capitals game, learn state capitals, USA states quiz, 50 states capitals, state capitals map">
  <meta name="robots" content="index, follow">
  <link rel="canonical" href="https://usa-states-re4o.onrender.com/capitals-quiz">

  <meta property="og:type" content="website">
  <meta property="og:title" content="Cap Quest — USA State Capitals Quiz &amp; Map">
  <meta property="og:description" content="Collect a stamp from every state capital in the union — a postcard-themed quiz, flashcard game, and map for all 50 states.">
  <meta property="og:url" content="https://usa-states-re4o.onrender.com/capitals-quiz">

  <meta name="twitter:card" content="summary">
  <meta name="twitter:title" content="Cap Quest — USA State Capitals Quiz &amp; Map">
  <meta name="twitter:description" content="Collect a stamp from every state capital in the union — a postcard-themed quiz, flashcard game, and map for all 50 states.">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
  <%- include('layout') %>

  <style>
    .quiz-page {
      --paper: #f5ead0;
      --paper-2: #eeddb8;
      --paper-shadow: #cdb27e;
      --ink: #1b3a4b;
      --ink-soft: rgba(27,58,75,0.62);
      --ink-faint: rgba(27,58,75,0.32);
      --rust: #c44a26;
      --rust-ink: #a53c1c;
      --mustard: #e3a220;
      --forest: #2f7d4f;
      --desk: #e4d6ab;
      --desk-2: #d2bf87;
      --line: rgba(27,58,75,0.25);
      --radius: 4px;
      --font-display: Futura, "Century Gothic", "Trebuchet MS", sans-serif;
      --font-body: Georgia, "Iowan Old Style", "Palatino Linotype", serif;
      --font-mono: "Courier New", Courier, monospace;
      /* region ink colors — vivid, travel-poster saturated */
      --r-northeast: #2f7a8c;
      --r-south: #d9691d;
      --r-midwest: #c99a1f;
      --r-mountain: #3f8a5c;
      --r-southwest: #b8532e;
      --r-pacific: #35608f;
    }
    @media (prefers-color-scheme: dark) {
      .quiz-page { --desk: #17303d; --desk-2: #0f2028; --paper-shadow: #a98f5c; --line: rgba(245,234,208,0.22); }
    }
    .quiz-page[data-theme="dark"]  { --desk: #17303d; --desk-2: #0f2028; --paper-shadow: #a98f5c; --line: rgba(245,234,208,0.22); }
    .quiz-page[data-theme="light"] { --desk: #e4d6ab; --desk-2: #d2bf87; --paper-shadow: #cdb27e; --line: rgba(27,58,75,0.25); }

    .quiz-page * { box-sizing: border-box; }
    .quiz-page {
      background:
        radial-gradient(ellipse at 18% -8%, color-mix(in srgb, var(--mustard) 22%, transparent), transparent 55%),
        var(--desk);
      color: var(--ink);
      font-family: var(--font-body);
      padding: 2.2rem 1.2rem 4rem;
    }
    .quiz-page h1, .quiz-page h2, .quiz-page h3 { text-wrap: balance; }

    .atlas { max-width: 960px; margin: 0 auto; }

    /* ---------- Masthead ---------- */
    .masthead { display: flex; align-items: center; gap: 1.4rem; margin-bottom: 1.2rem; }
    .title-block { flex: 1; min-width: 0; }
    .eyebrow {
      font-family: var(--font-mono);
      font-size: .68rem;
      letter-spacing: .22em;
      color: var(--ink-soft);
      margin: 0 0 .35rem;
      text-transform: uppercase;
    }
    .masthead h1 {
      font-family: var(--font-display);
      font-weight: 700;
      font-size: clamp(1.9rem, 5vw, 2.9rem);
      letter-spacing: .01em;
      margin: 0 0 .3rem;
      color: var(--ink);
    }
    .tagline { margin: 0; font-size: .95rem; color: var(--ink-soft); font-style: italic; }
    .stat-badge {
      flex-shrink: 0;
      width: 84px;
      height: 84px;
      border-radius: 50%;
      border: 2px dashed var(--rust);
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      color: var(--rust-ink);
      background: color-mix(in srgb, var(--paper) 65%, transparent);
      transform: rotate(-6deg);
    }
    .stat-badge.streak { border-color: var(--forest); color: var(--forest); transform: rotate(5deg); }
    .stat-badge .pm-num { font-family: var(--font-display); font-weight: 700; font-size: 1.5rem; line-height: 1; }
    .stat-badge .pm-label { font-family: var(--font-mono); font-size: .55rem; letter-spacing: .14em; margin-top: .15rem; }

    /* ---------- Mode grid (tile nav) ---------- */
    .mode-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(104px, 1fr));
      gap: .6rem;
      margin-bottom: 1.4rem;
    }
    .mode-tile {
      aspect-ratio: 1 / 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      gap: .35rem;
      background: color-mix(in srgb, var(--tile-color, var(--rust)) 16%, var(--paper));
      border: 2px dashed color-mix(in srgb, var(--tile-color, var(--rust)) 70%, var(--ink-faint));
      border-radius: 10px;
      cursor: pointer;
      padding: .5rem;
      box-shadow: 0 4px 0 -1px var(--paper-shadow);
    }
    .mode-tile svg { width: 26px; height: 26px; color: var(--tile-color, var(--rust-ink)); }
    .mode-tile .mode-label {
      font-family: var(--font-display);
      font-size: .72rem;
      font-weight: 700;
      letter-spacing: .04em;
      text-transform: uppercase;
      color: var(--ink);
      text-align: center;
      line-height: 1.15;
    }
    .mode-tile.active {
      background: var(--tile-color, var(--rust));
      border-style: solid;
    }
    .mode-tile.active svg, .mode-tile.active .mode-label { color: var(--paper); }
    .mode-tile:hover { transform: translateY(-2px); }
    .mode-tile:focus-visible { outline: 2px solid var(--rust); outline-offset: 2px; }

    /* ---------- Stage ---------- */
    .stage {
      background: var(--paper);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      box-shadow: 0 18px 34px -22px rgba(0,0,0,.45), 0 1px 0 var(--paper-shadow) inset;
      padding: 1.6rem 1.6rem 1.8rem;
    }

    .route-progress { position: relative; height: 28px; margin-bottom: 1.3rem; border-bottom: 2px dashed var(--ink-faint); }
    .route-progress .plane {
      position: absolute; top: -11px; left: 0%;
      transform: translateX(-50%);
      font-size: 1rem;
      color: var(--rust-ink);
      transition: left .5s cubic-bezier(.2,.8,.3,1);
    }
    @media (prefers-reduced-motion: reduce) { .route-progress .plane { transition: none; } }
    .route-progress .dest { position: absolute; right: 0; top: -9px; font-size: .9rem; }

    .postcard-split { display: grid; grid-template-columns: 1fr 1px 1fr; gap: 1.4rem; align-items: start; }
    .postcard-split .divider { background: var(--ink-faint); align-self: stretch; }
    @media (max-width: 640px) {
      .postcard-split { grid-template-columns: 1fr; }
      .postcard-split .divider { display: none; }
    }

    .postcard-kicker { font-family: var(--font-mono); font-size: .72rem; letter-spacing: .14em; text-transform: uppercase; color: var(--ink-soft); margin: 0 0 .5rem; }
    #quizPrompt { font-family: var(--font-display); font-size: clamp(1.6rem, 4.4vw, 2.3rem); margin: 0 0 1rem; color: var(--rust-ink); }
    .link-btn { background: none; border: none; padding: 0; font-family: var(--font-mono); font-size: .78rem; color: var(--forest); text-decoration: underline dotted; cursor: pointer; }
    .link-btn:focus-visible { outline: 2px solid var(--rust); outline-offset: 3px; }

    .feedback-stamp { margin-top: 1.6rem; min-height: 3.4rem; }
    .feedback-stamp .stamp-text {
      display: inline-block;
      font-family: var(--font-display);
      font-weight: 700;
      font-size: 1.25rem;
      letter-spacing: .06em;
      text-transform: uppercase;
      border: 3px solid currentColor;
      border-radius: 8px;
      padding: .3rem .7rem;
      transform: rotate(-8deg);
      opacity: 0;
    }
    .feedback-stamp.show .stamp-text { animation: stampIn .35s ease-out forwards; }
    @media (prefers-reduced-motion: reduce) { .feedback-stamp.show .stamp-text { opacity: 1; animation: none; } }
    .feedback-stamp.correct .stamp-text { color: var(--forest); }
    .feedback-stamp.wrong .stamp-text { color: var(--rust-ink); }
    @keyframes stampIn {
      0% { opacity: 0; transform: rotate(-8deg) scale(2.4); }
      60% { opacity: 1; }
      100% { opacity: 1; transform: rotate(-8deg) scale(1); }
    }
    .feedback-note { font-family: var(--font-mono); font-size: .8rem; color: var(--ink-soft); margin-top: .5rem; }

    .options { display: grid; gap: .6rem; }
    .opt-btn {
      font-family: var(--font-body);
      font-size: .98rem;
      text-align: left;
      padding: .65rem .8rem;
      background: var(--paper-2);
      border: 1px solid var(--line);
      border-radius: var(--radius);
      cursor: pointer;
      color: var(--ink);
      display: flex;
      align-items: center;
      gap: .55rem;
    }
    .opt-btn .stub { font-family: var(--font-mono); font-size: .7rem; color: var(--ink-soft); border: 1px solid var(--ink-faint); border-radius: 2px; padding: .05rem .3rem; }
    .opt-btn:hover:not(:disabled) { border-color: var(--rust); }
    .opt-btn:focus-visible { outline: 2px solid var(--rust); outline-offset: 2px; }
    .opt-btn:disabled { cursor: default; }
    .opt-btn.is-correct { background: color-mix(in srgb, var(--forest) 20%, var(--paper-2)); border-color: var(--forest); }
    .opt-btn.is-wrong { background: color-mix(in srgb, var(--rust) 20%, var(--paper-2)); border-color: var(--rust); }

    .next-btn {
      margin-top: 1rem;
      font-family: var(--font-display);
      font-size: .82rem;
      letter-spacing: .06em;
      text-transform: uppercase;
      background: var(--ink);
      color: var(--paper);
      border: none;
      border-radius: var(--radius);
      padding: .65rem 1.1rem;
      cursor: pointer;
    }
    .next-btn:disabled { opacity: .35; cursor: default; }
    .next-btn:focus-visible { outline: 2px solid var(--rust); outline-offset: 2px; }

    /* ---------- Explore view ---------- */
    .region-block { margin-bottom: 1.7rem; }
    .region-block:last-child { margin-bottom: 0; }
    .region-head {
      display: flex;
      align-items: center;
      gap: .5rem;
      font-family: var(--font-display);
      font-size: .82rem;
      letter-spacing: .12em;
      text-transform: uppercase;
      color: var(--region-color, var(--ink-soft));
      margin: 0 0 .7rem;
      border-bottom: 2px solid var(--region-color, var(--line));
      padding-bottom: .35rem;
    }
    .region-head svg { width: 16px; height: 16px; color: var(--region-color, var(--rust-ink)); }

    .card-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(140px, 1fr)); gap: .7rem; }
    .flip-card { perspective: 800px; height: 120px; }
    .flip-card-inner {
      position: relative; width: 100%; height: 100%;
      transform-style: preserve-3d;
      transition: transform .5s cubic-bezier(.2,.8,.3,1);
    }
    @media (prefers-reduced-motion: reduce) { .flip-card-inner { transition: none; } }
    .flip-card.flipped .flip-card-inner { transform: rotateY(180deg); }
    .flip-face {
      position: absolute; inset: 0;
      backface-visibility: hidden;
      border: 1px solid var(--line);
      border-top: 4px solid var(--region-color, var(--rust));
      border-radius: var(--radius);
      padding: .55rem .6rem;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      cursor: pointer;
      background: color-mix(in srgb, var(--region-color, var(--rust)) 10%, var(--paper-2));
    }
    .flip-face:focus-visible { outline: 2px solid var(--rust); outline-offset: 2px; }
    .flip-front .abbr { font-family: var(--font-mono); font-size: .7rem; color: var(--ink-soft); }
    .flip-front .name { font-family: var(--font-display); font-weight: 700; font-size: .92rem; }
    .flip-front svg { width: 20px; height: 20px; color: var(--region-color, var(--ink-faint)); align-self: flex-end; }
    .flip-back {
      transform: rotateY(180deg);
      background: color-mix(in srgb, var(--region-color, var(--forest)) 22%, var(--paper));
      align-items: flex-start;
    }
    .flip-back .cap { font-family: var(--font-body); font-style: italic; font-weight: 700; font-size: .92rem; color: var(--ink); }
    .flip-back .lbl { font-family: var(--font-mono); font-size: .62rem; letter-spacing: .1em; color: var(--ink-soft); text-transform: uppercase; }
    .profile-link { font-family: var(--font-mono); font-size: .66rem; letter-spacing: .03em; color: var(--rust-ink); text-decoration: underline dotted; align-self: flex-start; }
    .profile-link:focus-visible { outline: 2px solid var(--rust); outline-offset: 2px; }
    .mastered-mark { position: absolute; top: 4px; right: 4px; width: 16px; height: 16px; color: var(--rust-ink); }

    /* ---------- Map view ---------- */
    .map-hint { font-family: var(--font-mono); font-size: .78rem; color: var(--ink-soft); margin: 0 0 1rem; }
    .us-map { display: grid; grid-template-columns: repeat(12, 1fr); grid-template-rows: repeat(7, 1fr); gap: 3px; aspect-ratio: 12 / 7; }
    .us-tile {
      background: color-mix(in srgb, var(--tile-color, var(--ink-faint)) 45%, var(--paper-2));
      border: 1px solid var(--line);
      border-radius: 3px;
      display: flex;
      align-items: center;
      justify-content: center;
      position: relative;
      font-family: var(--font-mono);
      font-weight: 700;
      font-size: clamp(.5rem, 1.2vw, .72rem);
      color: var(--ink);
      cursor: pointer;
      padding: 0;
    }
    .us-tile.mastered { background: var(--tile-color, var(--rust)); color: var(--paper); border-color: transparent; }
    .us-tile:hover, .us-tile:focus-visible { transform: scale(1.1); z-index: 2; outline: 2px solid var(--rust); outline-offset: 1px; }
    .us-tile .mark { position: absolute; top: -6px; right: -4px; width: 12px; height: 12px; color: var(--paper); }
  </style>

  <div class="quiz-page">
    <div class="atlas">
      <header class="masthead">
        <div class="stat-badge">
          <span class="pm-num" id="statMastered">0</span>
          <span class="pm-label">/ 50 STAMPS</span>
        </div>
        <div class="title-block">
          <p class="eyebrow">A Fifty-State Road Trip</p>
          <h1>Cap Quest</h1>
          <p class="tagline">Collect a stamp from every state capital in the union.</p>
        </div>
        <div class="stat-badge streak">
          <span class="pm-num" id="statStreak">0</span>
          <span class="pm-label">STREAK</span>
        </div>
      </header>

      <nav class="mode-grid" id="modeGrid" aria-label="Pick a game mode or region"></nav>

      <main>
        <section id="quizView" class="stage">
          <div class="route-progress">
            <span class="plane" id="planeMarker" style="left:0%">&#9992;</span>
            <span class="dest">&#127937;</span>
          </div>

          <div class="postcard-split">
            <div class="msg-side">
              <p class="postcard-kicker" id="quizKicker">Which city is the capital of</p>
              <h2 id="quizPrompt">&mdash;</h2>
              <button class="link-btn" id="toggleDirection">&#8644; swap &mdash; name the state instead</button>
              <div class="feedback-stamp" id="feedbackStamp"></div>
            </div>
            <div class="divider" aria-hidden="true"></div>
            <div class="addr-side">
              <div class="options" id="quizOptions"></div>
              <button class="next-btn" id="nextBtn" disabled>Mail it &mdash; next postcard &#8594;</button>
            </div>
          </div>
        </section>

        <section id="exploreView" class="stage" hidden></section>

        <section id="mapView" class="stage" hidden>
          <p class="map-hint">TAP A STATE TO FLIP ITS POSTCARD — COLORED BY REGION, FILLED IN ONCE MASTERED.</p>
          <div class="us-map" id="usMap"></div>
        </section>
      </main>
    </div>
  </div>

  <script>
  (function () {
    "use strict";

    var STATES = [
      {name:"Alabama",capital:"Montgomery",abbr:"AL",region:"south"},
      {name:"Alaska",capital:"Juneau",abbr:"AK",region:"pacific"},
      {name:"Arizona",capital:"Phoenix",abbr:"AZ",region:"southwest"},
      {name:"Arkansas",capital:"Little Rock",abbr:"AR",region:"south"},
      {name:"California",capital:"Sacramento",abbr:"CA",region:"pacific"},
      {name:"Colorado",capital:"Denver",abbr:"CO",region:"mountain"},
      {name:"Connecticut",capital:"Hartford",abbr:"CT",region:"northeast"},
      {name:"Delaware",capital:"Dover",abbr:"DE",region:"northeast"},
      {name:"Florida",capital:"Tallahassee",abbr:"FL",region:"south"},
      {name:"Georgia",capital:"Atlanta",abbr:"GA",region:"south"},
      {name:"Hawaii",capital:"Honolulu",abbr:"HI",region:"pacific"},
      {name:"Idaho",capital:"Boise",abbr:"ID",region:"mountain"},
      {name:"Illinois",capital:"Springfield",abbr:"IL",region:"midwest"},
      {name:"Indiana",capital:"Indianapolis",abbr:"IN",region:"midwest"},
      {name:"Iowa",capital:"Des Moines",abbr:"IA",region:"midwest"},
      {name:"Kansas",capital:"Topeka",abbr:"KS",region:"midwest"},
      {name:"Kentucky",capital:"Frankfort",abbr:"KY",region:"south"},
      {name:"Louisiana",capital:"Baton Rouge",abbr:"LA",region:"south"},
      {name:"Maine",capital:"Augusta",abbr:"ME",region:"northeast"},
      {name:"Maryland",capital:"Annapolis",abbr:"MD",region:"northeast"},
      {name:"Massachusetts",capital:"Boston",abbr:"MA",region:"northeast"},
      {name:"Michigan",capital:"Lansing",abbr:"MI",region:"midwest"},
      {name:"Minnesota",capital:"Saint Paul",abbr:"MN",region:"midwest"},
      {name:"Mississippi",capital:"Jackson",abbr:"MS",region:"south"},
      {name:"Missouri",capital:"Jefferson City",abbr:"MO",region:"midwest"},
      {name:"Montana",capital:"Helena",abbr:"MT",region:"mountain"},
      {name:"Nebraska",capital:"Lincoln",abbr:"NE",region:"midwest"},
      {name:"Nevada",capital:"Carson City",abbr:"NV",region:"mountain"},
      {name:"New Hampshire",capital:"Concord",abbr:"NH",region:"northeast"},
      {name:"New Jersey",capital:"Trenton",abbr:"NJ",region:"northeast"},
      {name:"New Mexico",capital:"Santa Fe",abbr:"NM",region:"southwest"},
      {name:"New York",capital:"Albany",abbr:"NY",region:"northeast"},
      {name:"North Carolina",capital:"Raleigh",abbr:"NC",region:"south"},
      {name:"North Dakota",capital:"Bismarck",abbr:"ND",region:"midwest"},
      {name:"Ohio",capital:"Columbus",abbr:"OH",region:"midwest"},
      {name:"Oklahoma",capital:"Oklahoma City",abbr:"OK",region:"southwest"},
      {name:"Oregon",capital:"Salem",abbr:"OR",region:"pacific"},
      {name:"Pennsylvania",capital:"Harrisburg",abbr:"PA",region:"northeast"},
      {name:"Rhode Island",capital:"Providence",abbr:"RI",region:"northeast"},
      {name:"South Carolina",capital:"Columbia",abbr:"SC",region:"south"},
      {name:"South Dakota",capital:"Pierre",abbr:"SD",region:"midwest"},
      {name:"Tennessee",capital:"Nashville",abbr:"TN",region:"south"},
      {name:"Texas",capital:"Austin",abbr:"TX",region:"southwest"},
      {name:"Utah",capital:"Salt Lake City",abbr:"UT",region:"mountain"},
      {name:"Vermont",capital:"Montpelier",abbr:"VT",region:"northeast"},
      {name:"Virginia",capital:"Richmond",abbr:"VA",region:"south"},
      {name:"Washington",capital:"Olympia",abbr:"WA",region:"pacific"},
      {name:"West Virginia",capital:"Charleston",abbr:"WV",region:"south"},
      {name:"Wisconsin",capital:"Madison",abbr:"WI",region:"midwest"},
      {name:"Wyoming",capital:"Cheyenne",abbr:"WY",region:"mountain"}
    ];

    var REGIONS = [
      {key:"northeast", label:"Northeast", icon:"lighthouse", varName:"--r-northeast"},
      {key:"south", label:"South", icon:"palm", varName:"--r-south"},
      {key:"midwest", label:"Midwest", icon:"wheat", varName:"--r-midwest"},
      {key:"mountain", label:"Mountain", icon:"mountain", varName:"--r-mountain"},
      {key:"southwest", label:"Southwest", icon:"cactus", varName:"--r-southwest"},
      {key:"pacific", label:"Pacific", icon:"wave", varName:"--r-pacific"}
    ];
    var REGION_BY_KEY = {};
    REGIONS.forEach(function (r) { REGION_BY_KEY[r.key] = r; });
    var STATE_BY_ABBR = {};
    STATES.forEach(function (s) { STATE_BY_ABBR[s.abbr] = s; });

    var MAP_LAYOUT = [
      {abbr:"AK",col:1,row:1},{abbr:"ME",col:12,row:1},
      {abbr:"WA",col:2,row:2},{abbr:"ID",col:3,row:2},{abbr:"MT",col:4,row:2},{abbr:"ND",col:5,row:2},{abbr:"MN",col:6,row:2},{abbr:"WI",col:7,row:2},{abbr:"MI",col:8,row:2},{abbr:"NY",col:10,row:2},{abbr:"VT",col:11,row:2},{abbr:"NH",col:12,row:2},
      {abbr:"OR",col:2,row:3},{abbr:"WY",col:4,row:3},{abbr:"SD",col:5,row:3},{abbr:"IA",col:6,row:3},{abbr:"IL",col:7,row:3},{abbr:"IN",col:8,row:3},{abbr:"OH",col:9,row:3},{abbr:"PA",col:10,row:3},{abbr:"MA",col:11,row:3},{abbr:"CT",col:12,row:3},
      {abbr:"CA",col:2,row:4},{abbr:"NV",col:3,row:4},{abbr:"UT",col:4,row:4},{abbr:"CO",col:5,row:4},{abbr:"NE",col:6,row:4},{abbr:"MO",col:7,row:4},{abbr:"KY",col:8,row:4},{abbr:"WV",col:9,row:4},{abbr:"VA",col:10,row:4},{abbr:"NJ",col:11,row:4},{abbr:"RI",col:12,row:4},
      {abbr:"AZ",col:3,row:5},{abbr:"NM",col:4,row:5},{abbr:"KS",col:5,row:5},{abbr:"OK",col:6,row:5},{abbr:"AR",col:7,row:5},{abbr:"TN",col:8,row:5},{abbr:"NC",col:9,row:5},{abbr:"SC",col:10,row:5},{abbr:"MD",col:11,row:5},{abbr:"DE",col:12,row:5},
      {abbr:"TX",col:5,row:6},{abbr:"LA",col:7,row:6},{abbr:"MS",col:8,row:6},{abbr:"AL",col:9,row:6},{abbr:"GA",col:10,row:6},
      {abbr:"HI",col:1,row:7},{abbr:"FL",col:10,row:7}
    ];

    function icon(name) {
      var body = {
        lighthouse: '<path d="M10 21h4M9 21l1-13h4l1 13M9.5 8h5M10 5h4l-1-3h-2z" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M2 12l3-1M22 12l-3-1M4 8l2.5.5M20 8l-2.5.5" stroke="currentColor" stroke-width="1.3" stroke-linecap="round"/>',
        palm: '<path d="M12 21V11" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M12 11c0-3 2-4 5-5-2 3-2 5-5 5zM12 11c0-3-2-4-5-5 2 3 2 5 5 5zM12 10c1-3 3-4 6-3-2 2-3 4-6 3zM12 10c-1-3-3-4-6-3 2 2 3 4 6 3z" fill="currentColor"/>',
        wheat: '<path d="M12 21V6" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M12 7l-3-2M12 7l3-2M12 10l-3-2M12 10l3-2M12 13l-3-2M12 13l3-2M12 16l-3-2M12 16l3-2" stroke="currentColor" stroke-width="1.2" stroke-linecap="round"/>',
        mountain: '<path d="M2 19l7-11 4 6 2-3 7 8z" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linejoin="round"/><path d="M9 12l1.3 1.7L12 11" stroke="currentColor" stroke-width="1.1" fill="none" stroke-linejoin="round"/>',
        cactus: '<path d="M12 21V9a2 2 0 1 1 4 0v2M12 13H9a2 2 0 0 1-2-2V8M12 21H9" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/><circle cx="17" cy="6" r="1.6" fill="currentColor"/>',
        wave: '<path d="M2 10c2-2 4-2 6 0s4 2 6 0 4-2 6 0" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/><path d="M2 15c2-2 4-2 6 0s4 2 6 0 4-2 6 0" fill="none" stroke="currentColor" stroke-width="1.4" stroke-linecap="round"/>',
        stamp: '<path d="M5 5h14v14H5z" fill="none" stroke="currentColor" stroke-width="1.4" stroke-dasharray="2 1.6"/><path d="M9 13l2 2 4-5" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>',
        compass: '<circle cx="12" cy="12" r="9" fill="none" stroke="currentColor" stroke-width="1.4"/><path d="M15.5 8.5l-2.2 5-5 2.2 2.2-5z" fill="currentColor"/><circle cx="12" cy="12" r="1.1" fill="currentColor"/>'
      }[name] || "";
      return '<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg" aria-hidden="true">' + body + '</svg>';
    }

    // Same-origin now — the state profile lives on this same app, so the
    // link is just a relative path (works locally and once deployed).
    var STATE_INFO_URL = "";

    var STORE_KEY = "postcardAtlasMastery_v1";
    var mastery = {};
    try {
      var saved = localStorage.getItem(STORE_KEY);
      if (saved) mastery = JSON.parse(saved);
    } catch (e) { mastery = {}; }

    function saveMastery() {
      try { localStorage.setItem(STORE_KEY, JSON.stringify(mastery)); } catch (e) {}
    }
    function masteryCount(abbr) { return mastery[abbr] || 0; }
    function isMastered(abbr) { return masteryCount(abbr) >= 2; }
    function totalMastered() {
      var n = 0;
      STATES.forEach(function (s) { if (isMastered(s.abbr)) n++; });
      return n;
    }

    var streak = 0;

    function shuffle(arr) {
      var a = arr.slice();
      for (var i = a.length - 1; i > 0; i--) {
        var j = Math.floor(Math.random() * (i + 1));
        var t = a[i]; a[i] = a[j]; a[j] = t;
      }
      return a;
    }
    function sample(arr, n) { return shuffle(arr).slice(0, n); }

    function updateStatBar() {
      document.getElementById("statMastered").textContent = totalMastered();
      document.getElementById("statStreak").textContent = streak;
      var pct = (totalMastered() / STATES.length) * 100;
      document.getElementById("planeMarker").style.left = pct + "%";
    }

    /* ---------------- Quiz ---------------- */
    var reverse = false;
    var current = null;
    var lastAbbr = null;
    var answered = false;

    var kicker = document.getElementById("quizKicker");
    var prompt = document.getElementById("quizPrompt");
    var optionsWrap = document.getElementById("quizOptions");
    var nextBtn = document.getElementById("nextBtn");
    var feedbackStamp = document.getElementById("feedbackStamp");
    var toggleBtn = document.getElementById("toggleDirection");

    function pickState() {
      var unmastered = STATES.filter(function (s) { return !isMastered(s.abbr); });
      var pool = (unmastered.length && Math.random() < 0.7) ? unmastered : STATES;
      var candidates = pool.filter(function (s) { return s.abbr !== lastAbbr; });
      if (!candidates.length) candidates = pool;
      return candidates[Math.floor(Math.random() * candidates.length)];
    }

    function renderQuestion() {
      answered = false;
      nextBtn.disabled = true;
      feedbackStamp.className = "feedback-stamp";
      feedbackStamp.innerHTML = "";

      current = pickState();
      lastAbbr = current.abbr;

      var correctValue = reverse ? current.name : current.capital;
      kicker.textContent = reverse
        ? "Which state has the capital city of"
        : "Which city is the capital of";
      prompt.textContent = reverse ? current.capital : current.name;

      var wrongPool = STATES.filter(function (s) { return s.abbr !== current.abbr; });
      var wrongValues = sample(wrongPool, 3).map(function (s) { return reverse ? s.name : s.capital; });
      var opts = shuffle([correctValue].concat(wrongValues));

      optionsWrap.innerHTML = "";
      opts.forEach(function (val) {
        var btn = document.createElement("button");
        btn.className = "opt-btn";
        btn.type = "button";
        btn.innerHTML = '<span class="stub">' + (reverse ? "STATE" : "CITY") + '</span><span>' + val + "</span>";
        btn.addEventListener("click", function () { checkAnswer(val, btn, correctValue); });
        optionsWrap.appendChild(btn);
      });
    }

    function checkAnswer(selected, btnEl, correctValue) {
      if (answered) return;
      answered = true;

      var buttons = optionsWrap.querySelectorAll(".opt-btn");
      buttons.forEach(function (b) {
        b.disabled = true;
        var label = b.querySelector("span:last-child").textContent;
        if (label === correctValue) b.classList.add("is-correct");
        else if (b === btnEl) b.classList.add("is-wrong");
      });

      var correct = selected === correctValue;
      if (correct) {
        streak++;
        mastery[current.abbr] = masteryCount(current.abbr) + 1;
        feedbackStamp.className = "feedback-stamp show correct";
        feedbackStamp.innerHTML = '<span class="stamp-text">Correct</span>' +
          '<p class="feedback-note">' + current.name + " &mdash; " + current.capital + "</p>";
      } else {
        streak = 0;
        feedbackStamp.className = "feedback-stamp show wrong";
        feedbackStamp.innerHTML = '<span class="stamp-text">Return to sender</span>' +
          '<p class="feedback-note">' + current.name + " &mdash; " + current.capital + "</p>";
      }
      saveMastery();
      updateStatBar();
      refreshExploreMarks();
      refreshMapMarks();
      nextBtn.disabled = false;
      nextBtn.focus();
    }

    nextBtn.addEventListener("click", renderQuestion);
    toggleBtn.addEventListener("click", function () {
      reverse = !reverse;
      toggleBtn.textContent = reverse
        ? "⇄ swap — name the city instead"
        : "⇄ swap — name the state instead";
      renderQuestion();
    });

    /* ---------------- Explore ---------------- */
    var exploreView = document.getElementById("exploreView");
    var exploreBuilt = false;

    function buildExplore() {
      exploreView.innerHTML = "";
      REGIONS.forEach(function (region) {
        var states = STATES.filter(function (s) { return s.region === region.key; });
        var block = document.createElement("div");
        block.className = "region-block";
        block.dataset.region = region.key;
        block.style.setProperty("--region-color", "var(" + region.varName + ")");

        var head = document.createElement("div");
        head.className = "region-head";
        head.innerHTML = icon(region.icon) + "<span>" + region.label + "</span>";
        block.appendChild(head);

        var grid = document.createElement("div");
        grid.className = "card-grid";

        states.forEach(function (s) {
          var card = document.createElement("div");
          card.className = "flip-card";
          card.dataset.abbr = s.abbr;
          card.style.setProperty("--region-color", "var(" + region.varName + ")");
          card.innerHTML =
            '<div class="flip-card-inner">' +
              '<button type="button" class="flip-face flip-front" aria-label="Reveal capital of ' + s.name + '">' +
                (isMastered(s.abbr) ? '<span class="mastered-mark">' + icon("stamp") + '</span>' : "") +
                '<span class="abbr">' + s.abbr + '</span>' +
                '<span class="name">' + s.name + "</span>" +
                icon(region.icon) +
              '</button>' +
              '<div class="flip-face flip-back" role="button" tabindex="0" aria-label="Hide capital of ' + s.name + '">' +
                '<span class="lbl">Capital</span>' +
                '<span class="cap">' + s.capital + '</span>' +
                '<a class="profile-link" href="' + STATE_INFO_URL + '/?state=' + s.abbr + '">View full profile &#8594;</a>' +
              '</div>' +
            '</div>';
          var front = card.querySelector(".flip-front");
          var back = card.querySelector(".flip-back");
          var link = card.querySelector(".profile-link");
          function flip() { card.classList.toggle("flipped"); }
          front.addEventListener("click", flip);
          back.addEventListener("click", flip);
          back.addEventListener("keydown", function (e) {
            if (e.key === "Enter" || e.key === " ") { e.preventDefault(); flip(); }
          });
          link.addEventListener("click", function (e) { e.stopPropagation(); });
          link.addEventListener("keydown", function (e) { e.stopPropagation(); });
          grid.appendChild(card);
        });

        block.appendChild(grid);
        exploreView.appendChild(block);
      });
    }

    function refreshExploreMarks() {
      if (!exploreBuilt) return;
      exploreView.querySelectorAll(".flip-card").forEach(function (card) {
        var abbr = card.dataset.abbr;
        var mark = card.querySelector(".mastered-mark");
        if (isMastered(abbr) && !mark) {
          card.querySelector(".flip-front").insertAdjacentHTML("afterbegin", '<span class="mastered-mark">' + icon("stamp") + '</span>');
        }
      });
    }

    function flipAndScrollTo(abbr) {
      var card = exploreView.querySelector('.flip-card[data-abbr="' + abbr + '"]');
      if (!card) return;
      exploreView.querySelectorAll(".flip-card.flipped").forEach(function (c) { c.classList.remove("flipped"); });
      card.classList.add("flipped");
      card.scrollIntoView({ behavior: "smooth", block: "center" });
    }

    /* ---------------- Map ---------------- */
    var mapView = document.getElementById("mapView");
    var usMap = document.getElementById("usMap");
    var mapBuilt = false;

    function buildMap() {
      usMap.innerHTML = "";
      MAP_LAYOUT.forEach(function (tile) {
        var s = STATE_BY_ABBR[tile.abbr];
        var region = REGION_BY_KEY[s.region];
        var btn = document.createElement("button");
        btn.type = "button";
        btn.className = "us-tile" + (isMastered(s.abbr) ? " mastered" : "");
        btn.style.gridColumn = tile.col;
        btn.style.gridRow = tile.row;
        btn.style.setProperty("--tile-color", "var(" + region.varName + ")");
        btn.setAttribute("aria-label", s.name + ", capital " + s.capital);
        btn.dataset.abbr = s.abbr;
        btn.innerHTML = s.abbr + (isMastered(s.abbr) ? '<span class="mark">' + icon("stamp") + '</span>' : "");
        btn.addEventListener("click", function () { goToStateOnMap(s.abbr); });
        usMap.appendChild(btn);
      });
    }

    function refreshMapMarks() {
      if (!mapBuilt) return;
      usMap.querySelectorAll(".us-tile").forEach(function (tile) {
        var abbr = tile.dataset.abbr;
        var mastered = isMastered(abbr);
        tile.classList.toggle("mastered", mastered);
        if (mastered && !tile.querySelector(".mark")) {
          tile.insertAdjacentHTML("beforeend", '<span class="mark">' + icon("stamp") + '</span>');
        }
      });
    }

    /* ---------------- Mode grid (tile nav) ---------------- */
    var quizView = document.getElementById("quizView");
    var modeGrid = document.getElementById("modeGrid");

    function setActiveTile(id) {
      modeGrid.querySelectorAll(".mode-tile").forEach(function (t) { t.classList.toggle("active", t.id === id); });
    }

    function showQuiz() {
      quizView.hidden = false; exploreView.hidden = true; mapView.hidden = true;
      setActiveTile("tileQuiz");
    }
    function showMap() {
      quizView.hidden = true; exploreView.hidden = true; mapView.hidden = false;
      if (!mapBuilt) { buildMap(); mapBuilt = true; }
      setActiveTile("tileMap");
    }
    function showExplore() {
      quizView.hidden = true; exploreView.hidden = false; mapView.hidden = true;
      if (!exploreBuilt) { buildExplore(); exploreBuilt = true; }
      setActiveTile(null);
    }

    function goToRegion(key) {
      showExplore();
      var block = exploreView.querySelector('.region-block[data-region="' + key + '"]');
      if (block) block.scrollIntoView({ behavior: "smooth", block: "start" });
    }

    function goToStateOnMap(abbr) {
      showExplore();
      flipAndScrollTo(abbr);
    }

    function buildModeGrid() {
      var items = [
        {kind: "quiz", id: "tileQuiz", label: "Quiz", icon: "stamp", varName: "--rust"},
        {kind: "map", id: "tileMap", label: "Map", icon: "compass", varName: "--forest"}
      ].concat(REGIONS.map(function (r) {
        return {kind: "region", key: r.key, label: r.label, icon: r.icon, varName: r.varName};
      }));

      items.forEach(function (item) {
        var btn = document.createElement("button");
        btn.type = "button";
        btn.className = "mode-tile" + (item.kind === "quiz" ? " active" : "");
        if (item.id) btn.id = item.id;
        btn.style.setProperty("--tile-color", "var(" + item.varName + ")");
        btn.innerHTML = icon(item.icon) + '<span class="mode-label">' + item.label + "</span>";
        if (item.kind === "quiz") btn.addEventListener("click", showQuiz);
        else if (item.kind === "map") btn.addEventListener("click", showMap);
        else btn.addEventListener("click", function () { goToRegion(item.key); });
        modeGrid.appendChild(btn);
      });
    }

    buildModeGrid();
    updateStatBar();
    renderQuestion();
  })();
  </script>
</body>
</html>
